    "import numpy as np\n",
    "weight = [0.1 , 0.2 , 0.3 , 0.4]\n",
    "def neural_network(input, weight):\n",
    "    prediction = np.dot(input, weight)\n",
    "    return prediction\n",
    "nubmer_of_toes = [8.5, 9.5, 9.9, 9.0]\n",
    "input = nubmer_of_toes[0]\n",
    "pred = neural_network(input, weight)\n",
    "print(pred)\n"
   ]
  }
